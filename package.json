{
  "name": "morse",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "happy-dom": "^20.9.0",
    "knip": "^6.16.1",
    "lefthook": "^2.1.9",
    "turbo": "^2.0.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo build",
    "test": "turbo test",
    "check": "turbo check",
    "typecheck": "turbo typecheck",
    "dev": "turbo dev",
    "knip": "knip",
    "setup:python": "uv sync --directory packages/ml/model && uv sync --directory packages/ml/cw-dsp-research",
    "model:export": "turbo run sync:web --filter=cw-model",
    "model:train": "turbo run train --filter=cw-model",
    "bump": "bunx bumpp packages/morse-audio/package.json && bunx bumpp packages/react-morse-audio/package.json",
    "publish:packages": "npm publish --workspace packages/morse-audio --workspace packages/react-morse-audio --access public"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/ml/model",
    "apps/*"
  ]
}
